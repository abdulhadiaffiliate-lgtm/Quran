{"1":[{"t":"By the morning brightness","r":"wal-ḍuḥā"}],"2":[{"t":"And the night","r":"wa-al-layli"},{"t":"when","r":"idhā"},{"t":"it covers with darkness","r":"sajā"}],"3":[{"t":"Not","r":"mā"},{"t":"has forsaken you","r":"waddaʿaka"},{"t":"your Lord","r":"rabbuka"},{"t":"and not","r":"wamā"},{"t":"He is displeased","r":"qalā"}],"4":[{"t":"And surely the Hereafter","r":"walalākhiratu"},{"t":"(is) better","r":"khayrun"},{"t":"for you","r":"laka"},{"t":"than","r":"mina"},{"t":"the first","r":"l-ūlā"}],"5":[{"t":"And soon","r":"walasawfa"},{"t":"will give you","r":"yuʿ'ṭīka"},{"t":"your Lord","r":"rabbuka"},{"t":"then you will be satisfied","r":"fatarḍā"}],"6":[{"t":"Did not","r":"alam"},{"t":"He find you","r":"yajid'ka"},{"t":"an orphan","r":"yatīman"},{"t":"and give shelter","r":"faāwā"}],"7":[{"t":"And He found you","r":"wawajadaka"},{"t":"lost","r":"ḍāllan"},{"t":"so He guided","r":"fahadā"}],"8":[{"t":"And He found you","r":"wawajadaka"},{"t":"in need","r":"ʿāilan"},{"t":"so He made self-sufficient","r":"fa-aghnā"}],"9":[{"t":"So as for","r":"fa-ammā"},{"t":"the orphan","r":"l-yatīma"},{"t":"then (do) not","r":"falā"},{"t":"oppress","r":"taqhar"}],"10":[{"t":"And as for","r":"wa-ammā"},{"t":"one who asks","r":"l-sāila"},{"t":"then (do) not","r":"falā"},{"t":"repel","r":"tanhar"}],"11":[{"t":"But as for","r":"wa-ammā"},{"t":"(the) Favor","r":"biniʿ'mati"},{"t":"(of) your Lord","r":"rabbika"},{"t":"narrate","r":"faḥaddith"}]}