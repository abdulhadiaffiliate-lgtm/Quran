{"1":[{"t":"Have you seen","r":"ara-ayta"},{"t":"the one who","r":"alladhī"},{"t":"denies","r":"yukadhibu"},{"t":"the Judgment","r":"bil-dīni"}],"2":[{"t":"Then that","r":"fadhālika"},{"t":"(is) the one who","r":"alladhī"},{"t":"repulses","r":"yaduʿʿu"},{"t":"the orphan","r":"l-yatīma"}],"3":[{"t":"And (does) not","r":"walā"},{"t":"feel the urge","r":"yaḥuḍḍu"},{"t":"to","r":"ʿalā"},{"t":"feed","r":"ṭaʿāmi"},{"t":"the poor","r":"l-mis'kīni"}],"4":[{"t":"So woe","r":"fawaylun"},{"t":"to those who pray","r":"lil'muṣallīna"}],"5":[{"t":"Those who","r":"alladhīna"},{"t":"[they]","r":"hum"},{"t":"about","r":"ʿan"},{"t":"their prayers","r":"ṣalātihim"},{"t":"(are) neglectful","r":"sāhūna"}],"6":[{"t":"Those who","r":"alladhīna"},{"t":"[they]","r":"hum"},{"t":"make show","r":"yurāūna"}],"7":[{"t":"And they deny","r":"wayamnaʿūna"},{"t":"[the] small kindnesses","r":"l-māʿūna"}]}