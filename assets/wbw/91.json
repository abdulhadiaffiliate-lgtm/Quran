{"1":[{"t":"By the sun","r":"wal-shamsi"},{"t":"and its brightness","r":"waḍuḥāhā"}],"2":[{"t":"And the moon","r":"wal-qamari"},{"t":"when","r":"idhā"},{"t":"it follows it","r":"talāhā"}],"3":[{"t":"And the day","r":"wal-nahāri"},{"t":"when","r":"idhā"},{"t":"it displays it","r":"jallāhā"}],"4":[{"t":"And the night","r":"wa-al-layli"},{"t":"when","r":"idhā"},{"t":"it covers it","r":"yaghshāhā"}],"5":[{"t":"And the heaven","r":"wal-samāi"},{"t":"and (He) Who","r":"wamā"},{"t":"constructed it","r":"banāhā"}],"6":[{"t":"And the earth","r":"wal-arḍi"},{"t":"and by (He) Who","r":"wamā"},{"t":"spread it","r":"ṭaḥāhā"}],"7":[{"t":"And (the) soul","r":"wanafsin"},{"t":"and (He) Who","r":"wamā"},{"t":"proportioned it","r":"sawwāhā"}],"8":[{"t":"And He inspired it","r":"fa-alhamahā"},{"t":"(to distinguish) its wickedness","r":"fujūrahā"},{"t":"and its righteousness","r":"wataqwāhā"}],"9":[{"t":"Indeed","r":"qad"},{"t":"he succeeds","r":"aflaḥa"},{"t":"who","r":"man"},{"t":"purifies it","r":"zakkāhā"}],"10":[{"t":"And indeed","r":"waqad"},{"t":"he fails","r":"khāba"},{"t":"who","r":"man"},{"t":"buries it","r":"dassāhā"}],"11":[{"t":"Denied","r":"kadhabat"},{"t":"Thamud","r":"thamūdu"},{"t":"by their transgression","r":"biṭaghwāhā"}],"12":[{"t":"When","r":"idhi"},{"t":"(was) sent forth","r":"inbaʿatha"},{"t":"(the) most wicked of them","r":"ashqāhā"}],"13":[{"t":"But said","r":"faqāla"},{"t":"to them","r":"lahum"},{"t":"(the) Messenger","r":"rasūlu"},{"t":"(of) Allah","r":"l-lahi"},{"t":"(It is the) she-camel","r":"nāqata"},{"t":"(of) Allah","r":"l-lahi"},{"t":"and her drink","r":"wasuq'yāhā"}],"14":[{"t":"But they denied him","r":"fakadhabūhu"},{"t":"and they hamstrung her","r":"faʿaqarūhā"},{"t":"So destroyed","r":"fadamdama"},{"t":"them","r":"ʿalayhim"},{"t":"their Lord","r":"rabbuhum"},{"t":"for their sin","r":"bidhanbihim"},{"t":"and leveled them","r":"fasawwāhā"}],"15":[{"t":"And not","r":"walā"},{"t":"He fears","r":"yakhāfu"},{"t":"its consequences","r":"ʿuq'bāhā"}]}